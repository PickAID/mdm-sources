{
  "identity": {
    "schemaVersion": 2,
    "packageId": "minecraft-26.1.2-neoforge-source-profile",
    "packageVersion": "0.1.0",
    "namespace": "minecraft",
    "displayName": "Minecraft 26.1.2 NeoForge Source Profile",
    "description": "Public NeoForge source acquisition profile for Minecraft 26.1.2. It describes legal local generation and cache policy without bundling source."
  },
  "target": {
    "minecraftVersions": [
      "26.1.2"
    ],
    "loaders": [
      "neoforge"
    ],
    "mappings": [
      "official",
      "mojmap",
      "parchment"
    ]
  },
  "artifact": {
    "kind": "docs_bundle",
    "format": "json",
    "schemaId": "mdm.sources.profile.json",
    "schemaVersion": 1,
    "entrypoint": "payload/source-profile.json"
  },
  "capabilities": [
    "source_lookup",
    "source_chunk_search"
  ],
  "policy": {
    "privacy": "public_release",
    "lifecycle": [
      "downloadable"
    ],
    "canCommitToRepository": true,
    "canUploadToPublicRelease": true,
    "requiresUserConsent": false
  },
  "query": {
    "adapter": "json_docs",
    "capabilities": [
      "source_lookup",
      "source_chunk_search"
    ],
    "defaultLimit": 8,
    "maxLimit": 50,
    "preferredFallbacks": [
      "source_index_sqlite"
    ]
  },
  "release": {
    "channel": "sources",
    "family": "loader-sources"
  }
}
