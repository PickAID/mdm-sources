{
  "identity": {
    "schemaVersion": 2,
    "packageId": "minecraft-1.20.1-yarn-mapping-profile",
    "packageVersion": "0.1.0",
    "namespace": "minecraft",
    "displayName": "Minecraft 1.20.1 Yarn Mapping Profile",
    "description": "Curated public mapping profile that explains mapping namespaces and points MCP to legal acquisition paths without bundling generated mapping datasets."
  },
  "target": {
    "minecraftVersions": ["1.20.1"],
    "loaders": ["fabric"],
    "mappings": ["official", "intermediary", "named", "yarn"]
  },
  "artifact": {
    "kind": "mapping_bundle",
    "format": "json",
    "schemaId": "mdm.mappings.profile.json",
    "schemaVersion": 1,
    "entrypoint": "payload/mapping-profile.json"
  },
  "capabilities": ["mapping_lookup", "mapping_explain"],
  "policy": {
    "privacy": "public_release",
    "lifecycle": ["downloadable"],
    "canCommitToRepository": true,
    "canUploadToPublicRelease": true,
    "requiresUserConsent": false
  },
  "query": {
    "adapter": "mapping_index",
    "capabilities": ["mapping_lookup", "mapping_explain"],
    "defaultLimit": 8,
    "maxLimit": 50,
    "preferredFallbacks": []
  },
  "release": {
    "channel": "mappings",
    "family": "vanilla-mappings"
  }
}
