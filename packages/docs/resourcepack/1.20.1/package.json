{
  "identity": {
    "schemaVersion": 2,
    "packageId": "resourcepack-1.20.1-guidance",
    "packageVersion": "0.1.0",
    "namespace": "resourcepack",
    "displayName": "Resource Pack 1.20.1 Guidance",
    "description": "Public resource pack guidance seed for asset formats, model and texture tracing, UI assets, shader resources, and cache-safe evidence chains."
  },
  "target": {
    "minecraftVersions": ["1.20.1"],
    "loaders": ["vanilla", "forge", "neoforge", "fabric", "quilt", "kubejs"]
  },
  "artifact": {
    "kind": "docs_bundle",
    "format": "json",
    "schemaId": "mdm.resourcepack.guidance.json",
    "schemaVersion": 1,
    "entrypoint": "payload/resourcepack-guidance.json"
  },
  "capabilities": ["docs_search", "docs_direct_read", "resourcepack_trace"],
  "policy": {
    "privacy": "public_release",
    "lifecycle": ["downloadable"],
    "canCommitToRepository": true,
    "canUploadToPublicRelease": true,
    "requiresUserConsent": false
  },
  "query": {
    "adapter": "json_docs",
    "capabilities": ["docs_search", "docs_direct_read", "resourcepack_trace"],
    "defaultLimit": 8,
    "maxLimit": 50,
    "preferredFallbacks": []
  },
  "release": {
    "channel": "docs",
    "family": "resourcepack-guidance"
  }
}
