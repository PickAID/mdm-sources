{
  "identity": {
    "schemaVersion": 2,
    "packageId": "client-visual-1.20.1-guidance",
    "packageVersion": "0.1.0",
    "namespace": "client-visual",
    "displayName": "Client Visual 1.20.1 Guidance",
    "description": "Public client visual guidance seed for UI, renderers, shaders, models, atlases, resource-pack assets, and evidence chains."
  },
  "target": {
    "minecraftVersions": ["1.20.1"],
    "loaders": ["vanilla", "forge", "neoforge", "fabric", "quilt", "kubejs"]
  },
  "artifact": {
    "kind": "docs_bundle",
    "format": "json",
    "schemaId": "mdm.client_visual.guidance.json",
    "schemaVersion": 1,
    "entrypoint": "payload/client-visual-guidance.json"
  },
  "capabilities": ["docs_search", "docs_direct_read", "resourcepack_trace"],
  "policy": {
    "privacy": "public_release",
    "lifecycle": ["downloadable"],
    "canCommitToRepository": true,
    "canUploadToPublicRelease": true,
    "requiresUserConsent": false
  },
  "query": {
    "adapter": "json_docs",
    "capabilities": ["docs_search", "docs_direct_read", "resourcepack_trace"],
    "defaultLimit": 8,
    "maxLimit": 50,
    "preferredFallbacks": []
  },
  "release": {
    "channel": "docs",
    "family": "client-visual"
  }
}
