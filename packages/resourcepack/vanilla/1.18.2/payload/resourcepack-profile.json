{
  "minecraftVersion": "1.18.2",
  "packMcmeta": {
    "packFormat": 8,
    "description": "Vanilla resourcepack pack_format for Minecraft 1.18.2."
  },
  "roots": [
    "assets/<namespace>/blockstates",
    "assets/<namespace>/font",
    "assets/<namespace>/lang",
    "assets/<namespace>/models",
    "assets/<namespace>/particles",
    "assets/<namespace>/shaders",
    "assets/<namespace>/sounds",
    "assets/<namespace>/textures"
  ],
  "traceRules": [
    {
      "kind": "model",
      "pathPattern": "assets/<namespace>/models/<path>.json",
      "lookupKey": "<namespace>:<path>"
    },
    {
      "kind": "texture",
      "pathPattern": "assets/<namespace>/textures/<path>.png",
      "lookupKey": "<namespace>:<path>"
    },
    {
      "kind": "lang",
      "pathPattern": "assets/<namespace>/lang/<locale>.json",
      "lookupKey": "<namespace>:<locale>"
    }
  ]
}
