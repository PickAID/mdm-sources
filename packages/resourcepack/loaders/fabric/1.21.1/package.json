{
  "identity": {
    "schemaVersion": 2,
    "packageId": "minecraft-1.21.1-fabric-resourcepack-profile",
    "packageVersion": "0.1.0",
    "namespace": "minecraft",
    "displayName": "Minecraft 1.21.1 Fabric Resourcepack Profile",
    "description": "Generated public Fabric loader-scoped resourcepack profile for Minecraft 1.21.1. It defines stable lookup roots and tells MCP to resolve exact pack metadata locally."
  },
  "target": {
    "minecraftVersions": [
      "1.21.1"
    ],
    "loaders": [
      "fabric"
    ],
    "mappings": [
      "official",
      "intermediary",
      "named",
      "yarn"
    ]
  },
  "artifact": {
    "kind": "resourcepack_bundle",
    "format": "json",
    "schemaId": "mdm.resourcepack.profile.json",
    "schemaVersion": 1,
    "entrypoint": "payload/resourcepack-profile.json"
  },
  "capabilities": [
    "resource_location_lookup",
    "resourcepack_trace"
  ],
  "policy": {
    "privacy": "public_release",
    "lifecycle": [
      "downloadable"
    ],
    "canCommitToRepository": true,
    "canUploadToPublicRelease": true,
    "requiresUserConsent": false
  },
  "query": {
    "adapter": "archive_content",
    "capabilities": [
      "resource_location_lookup",
      "resourcepack_trace"
    ],
    "defaultLimit": 8,
    "maxLimit": 50,
    "preferredFallbacks": []
  },
  "release": {
    "channel": "resourcepack",
    "family": "loader-resourcepack"
  }
}
