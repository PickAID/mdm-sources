{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MDM Release Manifest",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "packages"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "generatedAt": { "type": "string", "minLength": 1 },
    "packages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "packageId",
          "version",
          "namespace",
          "artifactType",
          "variant",
          "required",
          "format",
          "releaseChannel",
          "releaseFamily",
          "capabilities",
          "artifactName",
          "sha256",
          "sizeBytes"
        ],
        "properties": {
          "packageId": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 },
          "namespace": { "type": "string", "minLength": 1 },
          "artifactType": {
            "enum": ["docs", "datapack", "resourcepack", "mappings", "source_index", "source_tree", "accelerator"]
          },
          "artifactKind": {
            "enum": [
              "docs_bundle",
              "source_tree",
              "source_index",
              "mapping_bundle",
              "datapack_bundle",
              "resourcepack_bundle",
              "probejs_snapshot",
              "mod_archive_index",
              "embedding_bundle"
            ]
          },
          "queryAdapter": {
            "enum": [
              "json_docs",
              "sqlite_docs",
              "source_index_sqlite",
              "source_tree",
              "mapping_index",
              "archive_content",
              "embedding_index"
            ]
          },
          "variant": { "type": "string", "minLength": 1 },
          "required": { "type": "boolean" },
          "format": { "enum": ["json", "jsonl", "sqlite", "zip", "directory", "tar.zst"] },
          "releaseChannel": {
            "enum": ["required", "docs", "sources", "mappings", "datapack", "resourcepack", "accelerators"]
          },
          "releaseFamily": { "type": "string", "minLength": 1 },
          "capabilities": { "type": "array", "items": { "type": "string" } },
          "metadata": {
            "type": "object",
            "properties": {
              "storageKind": { "type": "string", "minLength": 1 },
              "installTier": { "type": "string", "minLength": 1 },
              "commitPolicy": { "type": "string", "minLength": 1 },
              "sqlite": {
                "type": "object",
                "properties": {
                  "databaseName": { "type": "string", "minLength": 1 },
                  "minUserVersion": { "type": "number" },
                  "requiredTables": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 }
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": true
          },
          "artifactName": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[^/\\\\]+$"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "sizeBytes": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
